        "$description": "Brand ramp; hue-shifts to cyan in dark mode"
      },
      "hover": {
        "$value": "{color.accent.40}",
        "$type": "color"
      },
      "subtle": {
        "$value": "{color.blue.100}",
        "$type": "color"
      },
      "onAccent": {
        "$value": "{color.grey.100}",
        "$type": "color",
        "$description": "Text/icon on a brand or filled surface"
      }
    },
    "text": {
      "default": {
        "$value": "{color.grey.5}",
        "$type": "color"
      },
      "muted": {
        "$value": "{color.grey.55}",
        "$type": "color"
      },
      "subtle": {
        "$value": "{color.grey.40}",
        "$type": "color",
        "$description": "Labels, ghost/outline text, placeholders-on-hover"
      },
      "inverted": {
        "$value": "{color.grey.100}",
        "$type": "color"
      },
      "link": {
        "$value": "{color.accent.50}",
        "$type": "color"
      }
