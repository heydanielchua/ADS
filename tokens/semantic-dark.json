      "contrast": {
        "$value": "{color.grey.5}",
        "$type": "color",
        "$description": "Always-dark floating surface (tooltips/Module). Inverts in dark mode to grey.5 for continued contrast."
      },
      "panel": {
        "$value": "{color.accent.80}",
        "$type": "color",
