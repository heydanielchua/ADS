      "success": {
        "$value": "{color.green.50}",
        "$type": "color"
      },
      "warning": {
        "$value": "{color.amber.50}",
        "$type": "color"
      },
      "info": {
        "$value": "{color.sky.50}",
        "$type": "color"
      }
